{
  "name": "aeon-test",
  "version": "0.1.1",
  "description": "Marble testing utilities for Aeon reactive streams",
  "license": "MIT",
  "author": "Josh Burgess",
  "repository": {
    "type": "git",
    "url": "https://github.com/joshburgess/aeon",
    "directory": "packages/test"
  },
  "homepage": "https://github.com/joshburgess/aeon#readme",
  "bugs": "https://github.com/joshburgess/aeon/issues",
  "keywords": ["reactive", "streams", "frp", "testing", "marble", "virtual-scheduler"],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "rm -rf dist && rollup -c rollup.config.mjs && tsc -p tsconfig.build.json && cp dist/index.d.ts dist/index.d.cts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "aeon-types": "workspace:*",
    "aeon-core": "workspace:*",
    "aeon-scheduler": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
