{
  "name": "@pulse/devtools",
  "version": "0.0.1",
  "description": "Debug instrumentation for Pulse reactive streams",
  "license": "MIT",
  "author": "Josh Burgess",
  "repository": {
    "type": "git",
    "url": "https://github.com/joshburgess/pulse",
    "directory": "packages/devtools"
  },
  "keywords": ["reactive", "streams", "frp", "devtools", "debugging", "tracing"],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "rm -rf dist && rollup -c rollup.config.mjs && tsc -p tsconfig.build.json && cp dist/index.d.ts dist/index.d.cts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@pulse/types": "workspace:*",
    "@pulse/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
